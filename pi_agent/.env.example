# Exo-Platform Pi Agent Configuration
# Copy this file to .env and customize for your Pi.

# ============ Server Connection ============
# IP address of the Exo-Platform server (your laptop or central server).
# Use the LAN IP, not localhost (unless running on same machine).
EXO_HOST=192.168.1.100

# TCP ports on the server. Must match server config.
EXO_CONTROL_PORT=1863
EXO_VIDEO_PORT=8612
EXO_TELEMETRY_PORT=8613


# ============ Identity ============
# Unique identifier for this Pi. Defaults to hostname if unset.
# Examples: pi-arm-left, pi-leg-right, pi-glasses-001
EXO_CLIENT_ID=pi-arm-left

# Simulation mode — skip all hardware I/O, return fake sensor values.
# Set to 1 for testing without hardware attached.
EXO_SIM_MODE=0


# ============ Protocol ============
# Heartbeat send interval (seconds). Must be less than server's HEARTBEAT_TIMEOUT_S.
EXO_HEARTBEAT_INTERVAL_S=5

# Retry interval on connection failure.
EXO_CONNECT_RETRY_S=1

# Video frames per second to stream to server.
EXO_VIDEO_FPS=15

# Telemetry polling rate (Hz). Higher = more data but more CPU.
EXO_TELEMETRY_HZ=10

# Maximum JSON control message size (bytes).
EXO_MAX_CONTROL_LINE_BYTES=65536


# ============ Device Config ============
# Path to the devices.json manifest.
EXO_DEVICES_CONFIG=./devices.json
