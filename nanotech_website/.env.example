# Exo-Platform Frontend Configuration
# Copy this to .env.local for local development.

# ============ Backend URL ============
# Where Next.js proxies API calls.
# Default: http://localhost:5000 (local server)
# Production: https://api.your-domain.com
EXO_BACKEND_URL=http://localhost:5000

# Frontend-facing API path (not the actual backend URL).
# Browser sees /api/exo/* and Next.js proxies to EXO_BACKEND_URL.
NEXT_PUBLIC_EXO_API_URL=/api/exo
