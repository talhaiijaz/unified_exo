# Exo-Platform Server Configuration
# Copy this file to .env and customize for your environment.
# All values shown here are the defaults.

# ============ Network ============
# Bind address for TCP listeners. Use 0.0.0.0 to accept from any IP.
EXO_HOST=0.0.0.0

# FastAPI HTTP server port.
EXO_HTTP_PORT=5000

# TCP port for Pi control channel (commands, heartbeat, ack/result).
EXO_CONTROL_PORT=1863

# TCP port for Pi video streaming (JPEG frames).
EXO_VIDEO_PORT=8612

# TCP port for Pi telemetry (sensor readings).
EXO_TELEMETRY_PORT=8613


# ============ Protocol ============
# How often Pis send heartbeats (seconds).
EXO_HEARTBEAT_INTERVAL_S=5

# Drop Pi session if no heartbeat for this many seconds.
EXO_HEARTBEAT_TIMEOUT_S=20

# Server-side MJPEG stream rate to browser.
EXO_VIDEO_STREAM_FPS=15

# Maximum JPEG frame size (bytes). 4MB default.
EXO_MAX_FRAME_BYTES=4000000

# Maximum JSON control message size (bytes). 64KB default.
EXO_MAX_CONTROL_LINE_BYTES=65536


# ============ Database ============
# Path to SQLite file. Auto-created on first run.
EXO_DATABASE_PATH=./exo_data.db


# ============ Authentication ============
# JWT signing secret. CHANGE IN PRODUCTION.
# Generate with: openssl rand -hex 32
EXO_JWT_SECRET=exo-platform-dev-secret-change-in-production

# JWT token lifetime in minutes. Default: 8 hours.
EXO_JWT_EXPIRE_MINUTES=480


# ============ CORS ============
# Comma-separated list of allowed origins.
# Restrict to known frontend URLs in production.
EXO_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000


# ============ Recordings ============
# Directory where video recordings are saved.
EXO_RECORDINGS_DIR=./recordings
