# /etc/udev/rules.d/99-teensy.rules
# Creates stable symlink /dev/teensy-eeg for the Teensy 4.1
# Find your idVendor/idProduct with: udevadm info /dev/ttyACM0 | grep ID_VENDOR_ID
#
# Teensy 4.1 USB CDC (PJRC):
SUBSYSTEM=="tty", ATTRS{idVendor}=="16c0", ATTRS{idProduct}=="0483", SYMLINK+="teensy-eeg", MODE="0666"

# If your Teensy shows a different product ID, run:
#   udevadm info -a -n /dev/ttyACM0 | grep idVendor
# and update the line above accordingly.
