# Production server config — copy to /etc/unified-server/server.env
# Do NOT commit real secrets to git.

EXO_HOST=0.0.0.0
EXO_HTTP_PORT=5000
EXO_CONTROL_PORT=1863
EXO_VIDEO_PORT=8612
EXO_TELEMETRY_PORT=8613
EXO_HEARTBEAT_INTERVAL_S=5
EXO_HEARTBEAT_TIMEOUT_S=20
EXO_VIDEO_STREAM_FPS=15
EXO_MAX_FRAME_BYTES=4000000
EXO_MAX_CONTROL_LINE_BYTES=65536
EXO_DATABASE_PATH=/var/lib/unified-server/exo_data.db
EXO_JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
EXO_JWT_EXPIRE_MINUTES=480
EXO_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://nanotechserver.ddns.net:8080
EXO_RECORDINGS_DIR=/var/lib/unified-server/recordings
